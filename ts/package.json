{
  "name": "@tabnas/proto",
  "version": "0.2.0",
  "description": "Parse Protocol Buffers .proto IDL (proto2, proto3, edition 2023/2024) into FileDescriptorProto-shaped JSON, using the Tabnas parser and an ABNF grammar.",
  "main": "dist/proto.js",
  "type": "commonjs",
  "types": "dist/proto.d.ts",
  "homepage": "https://github.com/tabnas/proto",
  "keywords": [
    "protobuf",
    "protocol-buffers",
    "proto",
    "proto2",
    "proto3",
    "editions",
    "tabnas",
    "parser",
    "abnf",
    "descriptor"
  ],
  "author": "Richard Rodger (http://richardrodger.com)",
  "repository": {
    "type": "git",
    "url": "git://github.com/tabnas/proto.git"
  },
  "scripts": {
    "test": "node --enable-source-maps --test \"dist-test/*.test.js\"",
    "test-some": "node --enable-source-maps --test-name-pattern=\"$npm_config_pattern\" --test \"dist-test/*.test.js\"",
    "embed": "node embed-grammar.js",
    "watch": "tsc --build src test -w",
    "build": "node embed-grammar.js && tsc --build src test",
    "clean": "rm -rf node_modules dist dist-test yarn.lock package-lock.json",
    "reset": "npm run clean && npm i && npm run build && npm test"
  },
  "license": "MIT",
  "files": [
    "src",
    "dist",
    "LICENSE"
  ],
  "peerDependencies": {
    "@tabnas/abnf": "^0.2.0",
    "@tabnas/parser": "^0.2.0"
  },
  "devDependencies": {
    "@tabnas/abnf": "file:../../abnf/ts",
    "@tabnas/parser": "^0.2.0",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  }
}
